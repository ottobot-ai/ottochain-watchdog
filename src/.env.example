# ===========================================
# OttoChain Health Monitor Configuration
# ===========================================

# ----- Node IPs -----
# Comma-separated list of metagraph node IPs
NODE_IPS=10.0.0.1,10.0.0.2,10.0.0.3
NODE_NAMES=node1,node2,node3

# ----- SSH Access -----
SSH_KEY_PATH=/root/.ssh/hetzner_ottobot
SSH_USER=root

# ----- Port Configuration -----
# Defaults shown - override if your setup differs
# GL0_PORT=9000
# ML0_PORT=9200
# CL1_PORT=9300
# DL1_PORT=9400

# ----- Thresholds -----
SNAPSHOT_STALL_MINUTES=4
HEALTH_CHECK_INTERVAL=60
RESTART_COOLDOWN_MINUTES=10
MAX_RESTARTS_PER_HOUR=6

# ----- Telegram Notifications -----
# Enable direct Telegram alerts from watchdog
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ----- HTTP API -----
# Enable REST API for external integrations (default: true)
API_ENABLED=true
API_PORT=3033

# ----- Legacy Notifications -----
# Discord webhook (deprecated, use Telegram)
# WEBHOOK_URL=https://discord.com/api/webhooks/...

# ----- Database -----
# Postgres for event persistence
DATABASE_URL=postgresql://ottochain:ottochain@localhost:5432/ottochain

# ----- Redis -----
# Redis for cached health data from services monitor
REDIS_URL=redis://localhost:6379
